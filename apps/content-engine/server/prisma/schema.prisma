generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Product Catalog ────────────────────────────────────────────────────────

model Product {
  id            String         @id @default(cuid())
  marketplace   String         // "amazon" | "mercadolibre"
  title         String
  price         Float
  rating        Float
  reviews       Int
  affiliateLink String         @default("")
  imageUrl      String         @default("")
  currency      String         @default("USD")
  score         Int            @default(0)
  sourceApi     String         @default("")
  lastSeen      DateTime       @default(now())
  createdAt     DateTime       @default(now())

  catalogEntries CatalogEntry[]

  @@map("products")
}

model CatalogEntry {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  minedAt        DateTime @default(now())
  market         String
  freshnessScore Float    @default(1.0)
  provenance     String   @default("") // e.g. "mining-session-xyz"

  scripts        Script[]

  @@map("catalog_entries")
}

// ─── Scripts ─────────────────────────────────────────────────────────────────

model Script {
  id             String        @id @default(cuid())
  catalogEntryId String?
  catalogEntry   CatalogEntry? @relation(fields: [catalogEntryId], references: [id])
  blueprintId    String
  text           String
  language       String        @default("en")
  confidence     Int           @default(0)
  version        Int           @default(1)
  prompt         String        @default("") // stored for audit
  createdAt      DateTime      @default(now())

  voiceovers     Voiceover[]
  deliveryJobs   DeliveryJob[]

  @@map("scripts")
}

// ─── Voiceovers ──────────────────────────────────────────────────────────────

model Voiceover {
  id              String        @id @default(cuid())
  scriptId        String
  script          Script        @relation(fields: [scriptId], references: [id])
  fileUrl         String
  duration        String        @default("")
  voiceModel      String
  voiceId         String        @default("")
  bitrate         String        @default("128kbps")
  stability       Float         @default(0.75)
  similarityBoost Float         @default(0.80)
  status          String        @default("completed")
  createdAt       DateTime      @default(now())

  deliveryJobs    DeliveryJob[]

  @@map("voiceovers")
}

// ─── Delivery Jobs ───────────────────────────────────────────────────────────

model DeliveryJob {
  id             String     @id @default(cuid())
  editorContact  String
  scriptId       String
  script         Script     @relation(fields: [scriptId], references: [id])
  voiceoverId    String?
  voiceover      Voiceover? @relation(fields: [voiceoverId], references: [id])
  scriptUrl      String
  voiceoverUrl   String?
  status         String     @default("pending") // pending | completed | failed
  sentAt         DateTime?
  createdAt      DateTime   @default(now())

  @@map("delivery_jobs")
}

// ─── Comment Reply Jobs ──────────────────────────────────────────────────────

model CommentReplyJob {
  id          String    @id @default(cuid())
  commentId   String
  videoId     String
  comment     String
  reply       String?
  status      String    @default("pending") // pending | completed | flagged | rejected
  source      String    @default("AI")      // "AI" | "human"
  flagged     Boolean   @default(false)
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@map("comment_reply_jobs")
}

// ─── Tool Credentials ────────────────────────────────────────────────────────

model ToolCredential {
  id               String   @id @default(cuid())
  toolId           String   @unique
  login            String   @default("")
  passwordEncrypted String  @default("") // AES-GCM encrypted, base64url
  iv               String   @default("") // base64url initialisation vector
  updatedAt        DateTime @updatedAt
  updatedBy        String   @default("") // user_id

  @@map("tool_credentials")
}

model MiningSession {
  id          String   @id @default(cuid())
  marketplace String
  category    String
  status      String   @default("pending") // pending | in_progress | completed | failed
  productCount Int     @default(0)
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@map("mining_sessions")
}
